generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// جدول المدربين
model Instructor {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  password        String
  phone           String?
  agreementSigned Boolean    @default(true)
  workshops       Workshop[]
  createdAt       DateTime   @default(now())
}

// جدول المناهج
model Curriculum {
  id          String     @id @default(cuid())
  title       String
  description String
  contentUrl  String?
  workshops   Workshop[]
}

// جدول الورش
model Workshop {
  id            String      @id @default(cuid())
  instructorId  String
  instructor    Instructor  @relation(fields: [instructorId], references: [id])
  curriculumId  String
  curriculum    Curriculum  @relation(fields: [curriculumId], references: [id])
  startDate     DateTime
  status        String      @default("UPCOMING")
  sessions      Session[]
  enrollments   Enrollment[]
}

// جدول الجلسات
model Session {
  id         String   @id @default(cuid())
  workshopId String
  workshop   Workshop @relation(fields: [workshopId], references: [id])
  topic      String
  date       DateTime
  isDone     Boolean  @default(false)
}

// جدول المتدربين
model Enrollment {
  id          String   @id @default(cuid())
  studentName String
  workshopId  String
  workshop    Workshop @relation(fields: [workshopId], references: [id])
  grade       Float?
  certificate String?
}

// ─── Career Assessment ────────────────────────────────────────────────────────
model Assessment {
  id              String   @id @default(cuid())
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  age             Int
  yearsExperience Int
  position        String
  // 21 answers stored as JSON array of integers [1-5]
  answers         Json
  // Computed stage scores (0-100)
  scoreChoice     Float
  scoreAdapt      Float
  scoreRole       Float
  scoreEffective  Float
  scoreEsteem     Float
  scoreRetire     Float
  overallScore    Float
  currentStage    String
  aiAnalysis      String?  @db.Text
  language        String   @default("ar")
  createdAt       DateTime @default(now())
}